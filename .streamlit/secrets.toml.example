# ─── Snowflake connection ─────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in real values.
# NEVER commit secrets.toml to git.
#
# Two auth_type options are supported:
#   "private_key" — RSA key-pair auth (recommended for production)
#   "password"    — username/password auth

# ── Option A: RSA private-key auth (recommended) ─────────────────────────────
[snowflake]
auth_type   = "private_key"
account     = "eixfvon-nha87547"
user        = "INTEGRATE_IO_USER"
role        = "INTEGRATE_IO_ROLE"
warehouse   = "INTEGRATE_IO_WAREHOUSE"
database    = "INTEGRATE_IO_DATABASE"
schema      = "RPTDB"
# Paste the full PEM block, including header/footer lines.
private_key = """
-----BEGIN PRIVATE KEY-----
<your base-64 encoded key here>
-----END PRIVATE KEY-----
"""

# ── Option B: password auth ───────────────────────────────────────────────────
# [snowflake]
# auth_type = "password"
# account   = "eixfvon-nha87547"
# user      = "INTEGRATE_IO_USER"
# password  = "<your password>"
# role      = "INTEGRATE_IO_ROLE"
# warehouse = "INTEGRATE_IO_WAREHOUSE"
# database  = "INTEGRATE_IO_DATABASE"
# schema    = "RPTDB"
