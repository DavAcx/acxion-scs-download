# ─── Snowflake connection ─────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in real values.
# NEVER commit secrets.toml to git.
#
# Two auth_type options are supported:
#   "private_key" — RSA key-pair auth (recommended for production)
#   "password"    — username/password auth

# ── Option A: RSA private-key auth (recommended) ─────────────────────────────
[snowflake]
auth_type   = "private_key"
account     = "eixfvon-nha87547"
user        = "INTEGRATE_IO_USER"
role        = "INTEGRATE_IO_ROLE"
warehouse   = "INTEGRATE_IO_WAREHOUSE"
database    = "INTEGRATE_IO_DATABASE"
schema      = "RPTDB"
# Paste the full PEM block, including header/footer lines.
private_key = """
-----BEGIN PRIVATE KEY-----
<your base-64 encoded key here>
-----END PRIVATE KEY-----
"""

# ── Option B: password auth ───────────────────────────────────────────────────
# [snowflake]
# auth_type = "password"
# account   = "eixfvon-nha87547"
# user      = "INTEGRATE_IO_USER"
# password  = "<your password>"
# role      = "INTEGRATE_IO_ROLE"
# warehouse = "INTEGRATE_IO_WAREHOUSE"
# database  = "INTEGRATE_IO_DATABASE"
# schema    = "RPTDB"

# ─── Microsoft OAuth (saved views authentication) ─────────────────────────────
# 1. Go to portal.azure.com → Azure Active Directory → App registrations → New registration
# 2. Name: "SCS Download App"  |  Supported account types: your org's tenant
# 3. Redirect URI (Web): https://acxion-scs-download.streamlit.app/oauth2callback
# 4. After creation, copy the Application (client) ID → client_id below
# 5. Certificates & secrets → New client secret → copy Value → client_secret below
# 6. Overview page → Directory (tenant) ID → tenant_id below
# 7. API permissions → Add → Microsoft Graph → User.Read (delegated) → Grant admin consent

[auth]
redirect_uri  = "https://acxion-scs-download.streamlit.app/oauth2callback"
cookie_secret = "<random 32+ character string — e.g. run: python -c \"import secrets; print(secrets.token_hex(32))\">"

[auth.microsoft]
client_id     = "<Application (client) ID from Azure App Registration>"
client_secret = "<Client Secret value from Azure App Registration>"
tenant_id     = "<Directory (tenant) ID from Azure — omit for multi-tenant>"
